[general]
"zprezto/runcoms/zprofile" = "~/.zprofile"
"zprezto/runcoms/zshrc" = "~/.zshrc"
"zprezto/runcoms/zshenv" = "~/.zshenv"
"zprezto/runcoms/zlogin" = "~/.zlogin"
"zprezto/runcoms/zlogout" = "~/.zlogout"
"zprezto/runcoms/zpreztorc" = "~/.zpreztorc"

# tmux
#"tmux/tmux.conf" = "~/.tmux.conf"
"tmux/tmux-custom/tmux.conf" = "~/.tmux.conf"
"tmux/tmux-custom/tmux.conf.local" = "~/.tmux.conf.local"

[macos]
"zsh/env.zsh" = "~/.env.zsh"
"zsh/abbrevs.zsh" = "~/.abbrevs.zsh"
"zsh/aliases.zsh" = "~/.aliases.zsh"

[linux]
"zsh/env-linux.zsh" = "~/.env.zsh"
"zsh/aliases-linux.zsh" = "~/.aliases.zsh"
"zsh/abbrevs.zsh" = "~/.abbrevs.zsh"
