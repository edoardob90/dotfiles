# dotlink.mac
# local symlinks on a Darwin machine

# Fish
fish,~/.config/fish

# ZSH
zsh/env-macos.zsh,~/.env.zsh
zsh/abbrevs.zsh,~/.abbrevs.zsh
zsh/aliases-macos.zsh,~/.aliases.local.zsh
ssh/config_macos,~/.ssh/config

# Bash
bash/bash_aliases.macos,~/.bash_aliases

# Tmux plugins
tmux/tmux,~/.tmux

# Other
alacritty.yml,.alacritty.yml
