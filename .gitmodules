[submodule "oh-my-zsh"]
	path = oh-my-zsh
	url = https://github.com/edoardob90/oh-my-zsh.git
[submodule "tmux"]
    path = tmux
    url = https://github.com/tony/tmux-config.git
[submodule "vendor/tmux-mem-cpu-load"]
    path = tmux/vendor/tmux-mem-cpu-load
    url = https://github.com/thewtex/tmux-mem-cpu-load.git
[submodule "pure"]
	path = pure
	url = https://github.com/sindresorhus/pure.git
[submodule "fzf"]
    path = fzf
    url = https://github.com/junegunn/fzf.git
[submodule "base16-shell"]
    path = base16-shell
    url = https://github.com/chriskempson/base16-shell.git
[submodule "zplug"]
	path = zplug
	url = ./zplug
